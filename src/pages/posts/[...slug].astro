---
import Footer from "@/components/Footer.astro"
import Header from "@/components/Header.astro"
import Layout from "@/layouts/Layout.astro"
import { getCollection } from "astro:content"
import { Calendar, Folder, Tag } from "lucide-react"

export async function getStaticPaths() {
  const posts = await getCollection("posts")
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post },
  }))
}

const { post } = Astro.props
const { title, date, updated, categories, tags } = post.data
const { Content } = await post.render()
const catList = categories
  ? Array.isArray(categories)
    ? categories
    : [categories]
  : []
---

<Layout
  title={`${title} - CallmeLins'Blog`}
  description={title}
>
  <Header />
  <main class="py-4">
    <article>
      <header class="mb-8 border-b pb-4">
        <h1
          class="mb-3 text-2xl font-medium"
        >
          {title}
        </h1>
        <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-muted-foreground">
          <span class="flex items-center gap-1">
            <Calendar size={14} />
            {new Date(date).toISOString().slice(0, 10)}
          </span>
          {updated && (
            <span class="flex items-center gap-1">
              <span>更新于</span>
              {new Date(updated).toISOString().slice(0, 10)}
            </span>
          )}
          {catList.length > 0 && (
            <span class="flex items-center gap-1">
              <Folder size={14} />
              {catList.map((cat: string) => (
                <a
                  href={`/categories#${cat}`}
                  class="underline underline-offset-2 hover:text-foreground"
                >
                  {cat}
                </a>
              ))}
            </span>
          )}
          {tags && tags.length > 0 && (
            <span class="flex flex-wrap items-center gap-1">
              <Tag size={14} />
              {tags.map((tag: string) => (
                <a
                  href={`/tags#${tag}`}
                  class="underline underline-offset-2 hover:text-foreground"
                >
                  #{tag}
                </a>
              ))}
            </span>
          )}
        </div>
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>

    <nav class="mt-12 border-t pt-4">
      <a
        href="/"
        class="text-sm text-muted-foreground underline underline-offset-2 hover:text-foreground"
      >
        &larr; 返回首页
      </a>
    </nav>
  </main>
  <Footer />
</Layout>
