---
import Footer from "@/components/Footer.astro"
import Header from "@/components/Header.astro"
import Layout from "@/layouts/Layout.astro"
import Content from "@/components/Content.astro"
---

<Layout title="404 - CallmeLins'Blog">
  <Header />
  <main class="space-y-4">
    <Content name="404" index={1}>
      <div class="py-8 text-center">
        <p class="text-4xl font-bold text-muted-foreground">404</p>
        <p class="mt-2 text-muted-foreground">页面不存在</p>
        <a
          href="/"
          class="mt-4 inline-block text-sm underline underline-offset-2 hover:text-foreground"
        >
          &larr; 返回首页
        </a>
      </div>
    </Content>
  </main>
  <Footer />
</Layout>
