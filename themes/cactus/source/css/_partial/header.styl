#header
  margin: 0 auto 2rem
  width: 100%

  h1, .h1
    margin-top: 0
    margin-bottom: 0
    color: $color-text
    letter-spacing: .01em
    font-weight: 700
    font-style: normal
    font-size: 1.5rem
    line-height: 2rem

    antialias()

  a
    background: none
    color: inherit
    text-decoration: none

  #logo
    display: inline-block
    float: left
    margin-right: 20px
    width: $logo-width
    height: $logo-height
    border-radius: 5px
    background-size: $logo-width $logo-height
    background-repeat: no-repeat
    if $logo-grayout
      filter: grayscale(100%)
      -webkit-filter: grayscale(100%)

  #nav
    color: $color-accent-1
    letter-spacing: .01em
    font-weight: 200
    font-style: normal
    font-size: .8rem

    ul
      margin: 0
      padding: 0
      list-style-type: none
      line-height: 15px

      a
        margin-right: 15px
        color: $color-accent-1

      a:hover
        underline(5px, $color-accent-1)

      .theme-toggle
        margin-right: 15px

      li
        display: inline-block
        margin-right: 15px
        border-right: 1px dotted
        border-color: $color-accent-1
        vertical-align: middle

      button.theme-toggle
        border: 0
        background: none
        padding: 0
        color: $color-accent-1
        font: inherit
        cursor: pointer

        &:hover
          underline(5px, $color-accent-1)

        i
          margin-right: 6px

      .icon
        display: none

      li:last-child
        margin-right: 0
        border-right: 0

        a
          margin-right: 0

if $logo-grayout
  #header:hover
    #logo
      filter: none
      -webkit-filter: none

@media screen and (max-width: 480px)
  #header
    > a.u-url
      display: flex
      align-items: center
      width: 100%
      min-width: 0
      padding-right: 0

    #logo
      float: none
      flex-shrink: 0

  #header #title
    flex: 1
    min-width: 0
    display: block
    margin-right: 0
    min-height: auto

    h1
      display: block
      font-size: 1.2rem
      line-height: 1.3
      overflow-wrap: anywhere

  #header #nav
    margin-top: .75rem

    ul
      display: flex
      flex-wrap: wrap
      align-items: center
      row-gap: .6rem
      a:hover
        background: none

      li
        display: inline-block
        border-right: 1px dotted $color-accent-1

      li.icon
        display: none !important

    ul
      button.theme-toggle
        padding: 0
        text-align: left
        min-width: auto
        min-height: auto
